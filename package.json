{
  "name": "riseup",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:push": "turbo run db:push --filter=@riseup/prisma",
    "db:migrate": "turbo run db:migrate --filter=@riseup/prisma",
    "db:generate": "turbo run db:generate --filter=@riseup/prisma",
    "db:studio": "turbo run db:studio --filter=@riseup/prisma"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "packageManager": "npm@10.5.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
